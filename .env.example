# Supabase (required)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: AI course generator (CourseGeneratorModal)
# WARNING: this is inlined into the public JS bundle by Vite at build time.
# Do NOT set this in a production deployment — anyone visiting the site could
# extract it from the bundle. Leave unset; users can paste their own key at
# runtime instead (stored in sessionStorage only, never sent to your server).
VITE_ANTHROPIC_API_KEY=
