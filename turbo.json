{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**"]
    },
    "app#build": {
      "outputs": ["dist/**"]
    },
    "marketing#build": {
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["SUPABASE_URL", "SUPABASE_ANON_KEY", "APP_ORIGIN", "NEXT_PUBLIC_APP_ORIGIN"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {},
    "test": {}
  }
}
