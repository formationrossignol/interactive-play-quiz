# Supabase (required) — same project as apps/app, server-only (no NEXT_PUBLIC_
# prefix: these pages fetch content in Server Components only).
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Same project again, client-exposed — used by client components that need
# to check auth state or call an edge function (e.g. the /pricing Pro CTA).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: override the app deployment the fallback rewrite proxies to.
# APP_ORIGIN=https://interactive-play-quiz.vercel.app
# NEXT_PUBLIC_APP_ORIGIN=https://interactive-play-quiz.vercel.app
